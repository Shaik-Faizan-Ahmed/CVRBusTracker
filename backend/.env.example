# CVR Bus Tracker Backend Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/cvr-bus-tracker
# For production, use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cvr-bus-tracker

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Firebase Configuration (for push notifications)
FIREBASE_SERVER_KEY=your-firebase-server-key-here
# For production, use service account JSON:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project"}

# CORS Configuration (for frontend)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Notification Settings
NOTIFICATION_RADIUS_KM=1
DEFAULT_AVERAGE_SPEED_KMH=25